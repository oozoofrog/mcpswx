{
  "version": 1,
  "servers": {
    "swift-yf-tools": {
      "repo": "oozoofrog/swift-yf-tools",
      "description": "Yahoo Finance API MCP Server for Swift",
      "executable": "swift-yf-tools",
      "args": ["mcp", "serve"],
      "platforms": {
        "macos-arm64": {
          "artifact": "swift-yf-tools-macos-arm64.tar.gz"
        },
        "macos-x86_64": {
          "artifact": "swift-yf-tools-macos-x86_64.tar.gz"
        }
      },
      "source": {
        "buildPath": "CLI",
        "buildCommand": "swift build -c release",
        "product": "swift-yf-tools"
      }
    },
    "mcpswx": {
      "repo": "oozoofrog/mcpswx",
      "description": "Swift MCP Platform — 런타임, 생성기, MCP 서버",
      "executable": "mcpswx",
      "args": ["mcp"],
      "platforms": {
        "macos-arm64": {
          "artifact": "mcpswx-macos-arm64.tar.gz"
        },
        "macos-x86_64": {
          "artifact": "mcpswx-macos-x86_64.tar.gz"
        }
      },
      "source": {
        "buildPath": ".",
        "buildCommand": "swift build -c release",
        "product": "mcpswx"
      }
    }
  }
}
